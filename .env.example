# Copy this file to .env and fill in real values before running locally.

# Core runtime
NODE_ENV=development
PORT=3001

# Postgres
POSTGRES_DB=trend2earn
POSTGRES_USER=trend_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql://trend_user:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/trend2earn

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=CHANGE_ME_JWT_SECRET

# AI / external services
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
COINGECKO_API_KEY=

# Solana / on-chain
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
ORACLE_PRIVATE_KEY=CHANGE_ME_ORACLE_PRIVATE_KEY
REWARD_MINT_ADDRESS=CHANGE_ME_REWARD_MINT_ADDRESS
ESCROW_ACCOUNT=CHANGE_ME_ESCROW_ACCOUNT

# Market data
PUMPFUN_API_URL=https://frontend-api.pump.fun
PUMPFUN_WS_URL=wss://frontend-api.pump.fun

# Frontend/public vars
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_AGENT_DEPLOYMENT_ADDRESS=11111111111111111111111111111111
FRONTEND_URL=http://localhost:3000

# Email/notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_PASS
SMTP_FROM=noreply@trend2earn.com
EMAIL_FROM=noreply@trend2earn.com

# App security / misc
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
LOG_LEVEL=info
VECTOR_ENDPOINT=http://vector:8000
EMBEDDING_MODEL=text-embedding-3-small
