# Development Environment Configuration
# Trend2Earn Platform

# Database Configuration
POSTGRES_DB=trend2earn
POSTGRES_USER=trend_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql://trend_user:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/trend2earn

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=7d

# Solana Configuration
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta

# PumpFun API Configuration
PUMPFUN_API_URL=https://frontend-api.pump.fun
PUMPFUN_WS_URL=wss://frontend-api.pump.fun

# TREND Token Configuration
TREND_TOKEN_MINT=YOUR_TREND_TOKEN_MINT_ADDRESS
TREND_TOKEN_DECIMALS=9

# API Configuration
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Coin Tracking Configuration
COIN_TRACKER_INTERVAL=60000
COIN_TRACKER_BATCH_SIZE=100
COIN_TRACKER_RETRY_ATTEMPTS=3

# Reward Distribution Configuration
REWARD_DISTRIBUTION_INTERVAL=604800000
REWARD_MIN_PERFORMANCE_SCORE=1.5
REWARD_TREND_CREATOR_PERCENTAGE=30
REWARD_COIN_SPOTTER_PERCENTAGE=50
REWARD_EARLY_SUPPORTER_PERCENTAGE=20

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=combined

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@trend2earn.com

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
