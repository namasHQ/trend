# Production Environment Configuration
# Trend2Earn Platform

# Database Configuration
POSTGRES_DB=trend2earn_prod
POSTGRES_USER=trend_user
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
DATABASE_URL=postgresql://trend_user:${POSTGRES_PASSWORD}@postgres:5432/trend2earn_prod

# Redis Configuration
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# JWT Configuration
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=7d

# Solana Configuration
SOLANA_RPC_URL=${SOLANA_RPC_URL}
SOLANA_WS_URL=${SOLANA_WS_URL}
SOLANA_NETWORK=mainnet-beta

# PumpFun API Configuration
PUMPFUN_API_URL=${PUMPFUN_API_URL}
PUMPFUN_WS_URL=${PUMPFUN_WS_URL}

# TREND Token Configuration
TREND_TOKEN_MINT=${TREND_TOKEN_MINT}
TREND_TOKEN_DECIMALS=9

# API Configuration
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=production

# Frontend Configuration
NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
NEXT_PUBLIC_SOLANA_RPC_URL=${NEXT_PUBLIC_SOLANA_RPC_URL}
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_APP_URL=${NEXT_PUBLIC_APP_URL}

# Coin Tracking Configuration
COIN_TRACKER_INTERVAL=300000
COIN_TRACKER_BATCH_SIZE=50
COIN_TRACKER_RETRY_ATTEMPTS=5

# Reward Distribution Configuration
REWARD_DISTRIBUTION_INTERVAL=604800000
REWARD_MIN_PERFORMANCE_SCORE=2.0
REWARD_TREND_CREATOR_PERCENTAGE=30
REWARD_COIN_SPOTTER_PERCENTAGE=50
REWARD_EARLY_SUPPORTER_PERCENTAGE=20

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=combined

# CORS Configuration
CORS_ORIGIN=${NEXT_PUBLIC_APP_URL}
CORS_CREDENTIALS=true

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Email Configuration (for notifications)
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASS=${SMTP_PASS}
EMAIL_FROM=${EMAIL_FROM}

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=${SESSION_SECRET}

# Backup Configuration
BACKUP_INTERVAL=86400000
BACKUP_RETENTION_DAYS=30
